# ----------------------------------------------------------------------------
# Deskly environment variables. Copy to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored — never commit real secrets.
# ----------------------------------------------------------------------------

# --- Database -----------------------------------------------------------------
# Local development uses SQLite via the libSQL driver adapter (zero setup).
# Production uses Turso (libsql://...) or Postgres — see docs/deployment.md.
DATABASE_URL="file:./dev.db"
# Auth token for a remote libSQL/Turso database. Leave empty for a local file DB.
DATABASE_AUTH_TOKEN=""

# --- Auth.js ------------------------------------------------------------------
# Session/JWT signing secret. Generate one with:  npx auth secret
AUTH_SECRET="generate-me-with-npx-auth-secret"
# Public origin of the app (used by Auth.js callbacks). Optional in dev.
AUTH_URL="http://localhost:3000"

# Absolute base URL — powers canonical tags, OG images, sitemap.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- OAuth (optional) ---------------------------------------------------------
# Sign-in buttons appear only when both the id and secret are set.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
